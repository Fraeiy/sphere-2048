# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# ── Express Server ────────────────────────────────────────────────────────────

# Port the Express server listens on (default: 5000)
PORT=5000

# Node environment (development | production | staging)
NODE_ENV=development

# Frontend URL for CORS configuration
FRONTEND_URL=http://localhost:3000

# ── Sphere / Unicity blockchain ───────────────────────────────────────────────

# Network to connect to (testnet | mainnet)
SPHERE_NETWORK=testnet

# Game treasury wallet mnemonic (BIP-39 seed phrase).
# If omitted, the SDK auto-generates a new wallet on first run.
GAME_TREASURY_MNEMONIC=

# Human-readable nametag for the treasury wallet (e.g. "2048game")
GAME_TREASURY_NAMETAG=sphere2048

# On-chain address for the treasury wallet (auto-detected if not set)
GAME_TREASURY_ADDRESS=

# Directory where the Sphere SDK stores wallet state (default: ./sphere-data)
# This directory should be excluded from version control.
SPHERE_DATA_DIR=./sphere-data

# Sphere API endpoints (usually auto-detected)
SPHERE_WALLET_URL=https://sphere.unicity.network
SPHERE_API_URL=https://api.unicity.network

# ── Database ──────────────────────────────────────────────────────────────────

# Database path (default: ./sphere-data/game.db)
# SQLite database file for user balances, scores, deposits
DATABASE_PATH=./sphere-data/game.db

# Database backup directory (optional)
DATABASE_BACKUP_DIR=./backups

# ── Security ──────────────────────────────────────────────────────────────────

# Enable CORS (true | false)
ENABLE_CORS=true

# Rate limiting: requests per time window
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# API key for admin endpoints (optional)
# API_KEY=your-secret-key-here

# ── Logging ───────────────────────────────────────────────────────────────────

# Log level (debug | info | warn | error)
LOG_LEVEL=info

# Enable request logging
LOG_REQUESTS=true

# ── Redis Database (Optional) ─────────────────────────────────────────────────

# Redis connection URL (optional - for production deployment).
# Leave empty for local development (uses SQLite).
# Example: redis://default:password@host:port

REDIS_URL=

