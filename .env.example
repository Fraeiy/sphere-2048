# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# ── Sphere / Unicity blockchain ───────────────────────────────────────────────

# Network to connect to (testnet | mainnet)
SPHERE_NETWORK=testnet

# Game treasury wallet mnemonic (BIP-39 seed phrase).
# If omitted, the SDK auto-generates a new wallet on first run.
GAME_TREASURY_MNEMONIC=

# Human-readable nametag for the treasury wallet (e.g. "2048game")
GAME_TREASURY_NAMETAG=

# On-chain address for the treasury wallet
GAME_TREASURY_ADDRESS=

# Directory where the Sphere SDK stores wallet state (default: ./sphere-data)
# This directory should be excluded from version control.
SPHERE_DATA_DIR=./sphere-data

# ── Server ────────────────────────────────────────────────────────────────────

# Port the Express server listens on (default: 5000)
PORT=5000
